# ─────────────────────────────────────────────────────────────────────────────
# BIES Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Comma-separated list of allowed CORS origins
CORS_ORIGIN="http://localhost:5173"

# ─── Database ─────────────────────────────────────────────────────────────────
# Dev: SQLite (fast local setup)
DATABASE_URL="file:./prisma/dev.db"

# Production: PostgreSQL (required for 500+ concurrent users)
# DATABASE_URL="postgresql://user:password@localhost:5432/bies?schema=public&connection_limit=20&pool_timeout=20"

# ─── Authentication ───────────────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-change-this-now"
JWT_EXPIRES_IN="7d"

# REQUIRED: Exactly 32 characters for AES-256-GCM key derivation
ENCRYPTION_SECRET="your-32-char-encryption-secret!!"

# ─── Redis (optional, but recommended for production) ─────────────────────────
# Enables distributed caching and rate limiting across multiple server instances.
# Falls back to in-memory cache if not set (single-instance only).
REDIS_URL="redis://localhost:6379"
# Cloud options: redis://user:password@hostname:port
# Upstash example: rediss://default:password@endpoint.upstash.io:6379

# ─── S3 Compatible Storage (AWS S3, Cloudflare R2, DigitalOcean Spaces) ──────
# Leave blank to use local file storage (uploads/ directory)
S3_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_BUCKET="bies-uploads"
# Public CDN URL for publicly accessible files (avatars, thumbnails)
S3_PUBLIC_URL="https://pub-xxxxx.r2.dev"

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated hex pubkeys that are auto-promoted to ADMIN on Nostr login
ADMIN_PUBKEYS=""

# ─── Nostr Relays ─────────────────────────────────────────────────────────────
NOSTR_RELAYS="wss://relay.damus.io,wss://relay.primal.net,wss://nos.lol"

# ─── Email (optional — for notification emails) ───────────────────────────────
# Leave blank to disable email notifications
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your-sendgrid-api-key"
SMTP_FROM="noreply@bies.io"
