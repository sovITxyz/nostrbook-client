# ─────────────────────────────────────────────────────────────────────────────
# Nostrbook Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"
# Production: PostgreSQL
# DATABASE_URL="postgresql://user:password@localhost:5432/nostrbook?schema=public&connection_limit=20&pool_timeout=20"

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-now"
JWT_EXPIRES_IN="7d"
ENCRYPTION_SECRET="your-32-char-encryption-secret!!"

# ─── Nostr Relays ─────────────────────────────────────────────────────────────
NOSTR_PRIVATE_RELAY="ws://localhost:7777"
NOSTR_PUBLIC_RELAY=""
NOSTR_RELAYS="wss://relay.damus.io,wss://relay.primal.net,wss://nos.lol"

# ─── Community Identity (WoT root for relay access) ──────────────────────────
# Hex keypair for the community identity that manages follow/mute lists.
COMMUNITY_PRIVKEY=""
COMMUNITY_PUBKEY=""

# ─── NIP-05 Domain ───────────────────────────────────────────────────────────
NIP05_DOMAIN=""

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_PUBKEYS=""

# ─── Redis (optional) ────────────────────────────────────────────────────────
REDIS_URL=""

# ─── S3 Compatible Storage (optional — falls back to local uploads/) ─────────
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="nostrbook-uploads"
S3_PUBLIC_URL=""

# ─── Email (optional) ────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@nostrbook.app"
