// Nostrbook Platform – Prisma Schema
// Production DB: PostgreSQL (change provider to "postgresql" for prod)
// Dev DB: SQLite (provider = "sqlite")

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// User & Auth
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  email            String?  @unique
  passwordHash     String?  @map("password_hash")
  nostrPubkey      String   @unique @map("nostr_pubkey")
  encryptedPrivkey String?  @map("encrypted_privkey")
  role             String   @default("MEMBER") // MEMBER | MODERATOR | ADMIN | EVENT_HOST | EDUCATOR
  isAdmin          Boolean  @default(false) @map("is_admin")
  isVerified       Boolean  @default(false) @map("is_verified")
  isBanned         Boolean  @default(false) @map("is_banned")
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  profile          Profile?
  projects         Project[]
  sessions         Session[]
  sentMessages     Message[]         @relation("SentMessages")
  receivedMessages Message[]         @relation("ReceivedMessages")
  bookmarks        Bookmark[]
  notifications    Notification[]
  pushSubscriptions PushSubscription[]
  following        Follow[]          @relation("Following")
  followers        Follow[]          @relation("Followers")
  hostedEvents     Event[]
  auditLogs        AuditLog[]
  projectViews     ProjectView[]
  teamMemberships  ProjectTeamMember[]
  eventRSVPs      EventAttendee[]
  settings         UserSettings?
  fingerprints     BrowserFingerprint[]
  feedback         Feedback[]
  reports          Report[]   @relation("ReportsBy")
  blocksCreated    Block[]    @relation("BlocksCreated")
  blocksReceived   Block[]    @relation("BlocksReceived")
  ageConfirmedAt   DateTime?  @map("age_confirmed_at")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Profile
// ─────────────────────────────────────────────────────────────────────────────

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  name         String   @default("")
  bio          String   @default("")
  avatar       String   @default("")
  banner       String   @default("")
  location     String   @default("")
  skills       String   @default("[]")  // JSON array
  website      String   @default("")
  twitter      String   @default("")
  linkedin     String   @default("")
  github       String   @default("")
  company      String   @default("")
  title        String   @default("")
  tags         String   @default("[]")  // JSON array
  // Profile sections
  experience     String   @default("[]")  // JSON array of {title,company,date,description}
  communityProjects String @default("[]") @map("community_projects") // JSON array of {id,name,role,status,image}
  customSections String   @default("[]") @map("custom_sections") // JSON array of {title,type,placement,body,...}
  showExperience Boolean  @default(true) @map("show_experience")
  nostrFeedMode  String   @default("combined") @map("nostr_feed_mode")
  nostrNpub      String   @default("") @map("nostr_npub")
  // NIP-05 & Lightning
  nip05Name        String?  @unique @map("nip05_name")
  lightningAddress String   @default("") @map("lightning_address")
  // Coinos custodial wallet
  coinosUsername   String?  @unique @map("coinos_username")
  coinosToken      String?  @map("coinos_token") // Encrypted JWT for Coinos API
  // Misc
  isPublic     Boolean  @default(true) @map("is_public")
  viewCount    Int      @default(0) @map("view_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// Project
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id           String   @id @default(cuid())
  title        String
  description  String
  category     String   @default("OTHER")
  // TECHNOLOGY | EDUCATION | COMMUNITY | CREATIVE | INFRASTRUCTURE | OTHER
  stage        String   @default("IDEA")
  // IDEA | MVP | GROWTH | SCALING
  thumbnail    String   @default("")
  demoUrl      String   @default("") @map("demo_url")
  websiteUrl   String   @default("") @map("website_url")
  tags         String   @default("[]") // JSON array
  customSections String  @default("[]") @map("custom_sections") // JSON array of { title, body }
  teamInfo     String   @default("[]") @map("team_info") // JSON array of { name, position, avatar }
  status       String   @default("draft") // draft | pending-review | active
  isPublished  Boolean  @default(true) @map("is_published")
  isFeatured   Boolean  @default(false) @map("is_featured")
  viewCount    Int      @default(0) @map("view_count")
  nostrEventId String?  @map("nostr_event_id")
  ownerId      String   @map("owner_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  owner        User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookmarks    Bookmark[]
  teamMembers  ProjectTeamMember[]
  views        ProjectView[]
  updates      ProjectUpdate[]
  zapReceipts  ZapReceipt[]

  @@map("projects")
}

model ProjectTeamMember {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String   @default("MEMBER") // FOUNDER | COFOUNDER | ADVISOR | MEMBER
  title     String   @default("")
  addedAt   DateTime @default(now()) @map("added_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_team_members")
}

model ProjectUpdate {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_updates")
}

model ProjectView {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String?  @map("user_id")
  ipAddress String?  @map("ip_address")
  viewedAt  DateTime @default(now()) @map("viewed_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("project_views")
}

// ─────────────────────────────────────────────────────────────────────────────
// Bookmarks (saved projects)
// ─────────────────────────────────────────────────────────────────────────────

model Bookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  projectId String   @map("project_id")
  note      String   @default("")
  addedAt   DateTime @default(now()) @map("added_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("bookmarks")
}

// ─────────────────────────────────────────────────────────────────────────────
// Messaging
// ─────────────────────────────────────────────────────────────────────────────

model Message {
  id          String   @id @default(cuid())
  senderId    String   @map("sender_id")
  recipientId String   @map("recipient_id")
  content     String   // Encrypted (NIP-04) or plaintext
  isEncrypted Boolean  @default(true) @map("is_encrypted")
  nostrEventId String? @map("nostr_event_id") // Reference to Nostr DM event
  isRead      Boolean  @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")

  sender    User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId, recipientId])
  @@index([recipientId, isRead])
  @@map("messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  // NEW_MESSAGE | PROJECT_VIEW | BOOKMARK_ADD
  // FOLLOW | PROJECT_UPDATE | SYSTEM
  title     String
  body      String
  data      String   @default("{}") // JSON metadata
  isRead    Boolean  @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// Push Subscriptions (Web Push API)
// ─────────────────────────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Events
// ─────────────────────────────────────────────────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  hostId      String   @map("host_id")
  title       String
  description String
  category    String   @default("NETWORKING")
  // NETWORKING | CONFERENCE | WORKSHOP | HACKATHON | MEETUP | DEMO_DAY | OTHER
  visibility  String   @default("PUBLIC") // PUBLIC | LIMITED_SPACES | INVITE_ONLY | PRIVATE | DRAFT
  location    String   @default("")
  isOnline    Boolean  @default(false) @map("is_online")
  onlineUrl   String   @default("") @map("online_url")
  startDate   DateTime @map("start_date")
  endDate     DateTime? @map("end_date")
  thumbnail   String   @default("")
  ticketUrl   String   @default("") @map("ticket_url")
  maxAttendees Int?    @map("max_attendees")
  isPublished Boolean  @default(true) @map("is_published")
  isFeatured  Boolean  @default(false) @map("is_featured")
  isOfficial  Boolean  @default(false) @map("is_official")
  isEndorsed  Boolean  @default(false) @map("is_endorsed")
  endorsementRequested Boolean @default(false) @map("endorsement_requested")
  guestList       String   @default("[]") @map("guest_list") // JSON array of {name, userId?}
  tags            String   @default("[]") // JSON array
  locationName    String   @default("") @map("location_name")
  locationAddress String   @default("") @map("location_address")
  locationMapUrl  String   @default("") @map("location_map_url")
  customSections  String   @default("[]") @map("custom_sections") // JSON array of {title, content}
  nostrEventId    String   @default("") @map("nostr_event_id") // NIP-52 calendar event id
  nostrPublish    String   @default("none") @map("nostr_publish") // none | community | public | both
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  host      User              @relation(fields: [hostId], references: [id], onDelete: Cascade)
  attendees EventAttendee[]

  @@map("events")
}

model EventAttendee {
  id            String   @id @default(cuid())
  eventId       String   @map("event_id")
  userId        String   @map("user_id")
  status        String   @default("GOING") // GOING | INTERESTED | NOT_GOING | INVITED
  nostrEventId  String?  @map("nostr_event_id") // NIP-52 RSVP event id (kind 31925)
  joinedAt      DateTime @default(now()) @map("joined_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_attendees")
}

// ─────────────────────────────────────────────────────────────────────────────
// Social: Following
// ─────────────────────────────────────────────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit Log
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String   // e.g. AUTH_LOGIN, PROJECT_CREATE, PROFILE_UPDATE
  resource  String   @default("") // e.g. "project:abc123"
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  String   @default("{}") // JSON
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}


// ─────────────────────────────────────────────────────────────────────────────
// Contact Submissions
// ─────────────────────────────────────────────────────────────────────────────

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  role      String   @default("") // MEMBER | ORGANIZER | MEDIA | OTHER
  message   String
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_submissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// User Feedback
// ─────────────────────────────────────────────────────────────────────────────

model Feedback {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  type       String    @default("GENERAL") // BUG | FEATURE | LOVE | GENERAL
  message    String
  status     String    @default("NEW") // NEW | IN_REVIEW | FIXED | WONT_FIX | PLANNED | DUPLICATE | CLOSED
  priority   String    @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  adminNote  String    @default("") @map("admin_note")
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("feedback")
}

// ─────────────────────────────────────────────────────────────────────────────
// Reports
// ─────────────────────────────────────────────────────────────────────────────

model Report {
  id          String    @id @default(cuid())
  reporterId  String    @map("reporter_id")
  targetType  String    @map("target_type")  // USER | POST | EVENT | PROJECT | MESSAGE
  targetId    String    @map("target_id")
  reason      String    // SPAM | HARASSMENT | VIOLENCE | ILLEGAL | NSFW | OTHER
  details     String    @default("")
  status      String    @default("PENDING")  // PENDING | REVIEWED | RESOLVED | DISMISSED
  adminNote   String    @default("") @map("admin_note")
  reviewedBy  String?   @map("reviewed_by")
  reviewedAt  DateTime? @map("reviewed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  reporter User @relation("ReportsBy", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([targetType, targetId])
  @@unique([reporterId, targetType, targetId])
  @@map("reports")
}

// ─────────────────────────────────────────────────────────────────────────────
// Blocks
// ─────────────────────────────────────────────────────────────────────────────

model Block {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("BlocksCreated", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocks")
}

// ─────────────────────────────────────────────────────────────────────────────
// User Settings
// ─────────────────────────────────────────────────────────────────────────────

model UserSettings {
  id                   String  @id @default(cuid())
  userId               String  @unique @map("user_id")
  emailNotifications   Boolean @default(true) @map("email_notifications")
  pushNotifications    Boolean @default(true) @map("push_notifications")
  marketingEmails      Boolean @default(false) @map("marketing_emails")
  notifyMessages       Boolean @default(true) @map("notify_messages")
  notifyBookmarks      Boolean @default(true) @map("notify_bookmarks")
  notifyFollows        Boolean @default(true) @map("notify_follows")
  notifyProjectUpdates Boolean @default(true) @map("notify_project_updates")
  relays               String  @default("[]") // JSON array of relay URLs
  mediaReadItems       String  @default("{}") @map("media_read_items") // JSON: { watched: [...], read: [...] }
  preferences          String  @default("{}") // JSON: { theme, language, projectsView, membersView, eventsView, mediaView }
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// Site Settings (singleton row for platform-wide config)
// ─────────────────────────────────────────────────────────────────────────────

model SiteSettings {
  id               String   @id @default("default")
  nostrNpubs       String   @default("[]") @map("nostr_npubs")
  twitterHandles   String   @default("[]") @map("twitter_handles")
  livestreamUrl    String   @default("") @map("livestream_url")
  livestreamActive Boolean  @default(false) @map("livestream_active")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// Content: Articles
// ─────────────────────────────────────────────────────────────────────────────

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String   @default("")
  content     String   // Full markdown/HTML content
  category    String   @default("NEWS") // NEWS | TUTORIAL | PLATFORM_UPDATE | LEGAL | GUIDE
  thumbnail   String   @default("")
  authorName  String   @default("") @map("author_name")
  isPublished Boolean  @default(false) @map("is_published")
  tags        String   @default("[]") // JSON array
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("articles")
}

// ─────────────────────────────────────────────────────────────────────────────
// Content: Videos
// ─────────────────────────────────────────────────────────────────────────────

model Video {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  url         String   // YouTube/embed URL
  thumbnail   String   @default("")
  category    String   @default("GENERAL") // GENERAL | TUTORIAL | INTERVIEW | DEMO
  duration    Int?     // seconds
  isPublished Boolean  @default(false) @map("is_published")
  tags        String   @default("[]") // JSON array
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("videos")
}

// ─────────────────────────────────────────────────────────────────────────────
// Content: Legal Resources
// ─────────────────────────────────────────────────────────────────────────────

model LegalResource {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  category    String   @default("GENERAL") // GENERAL | TERMS | PRIVACY | COMPLIANCE | TEMPLATE
  fileKey     String   @map("file_key") // S3 key or local path
  fileName    String   @default("") @map("file_name")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("legal_resources")
}

// ─────────────────────────────────────────────────────────────────────────────
// Zap Receipts (Lightning zaps via Nostr NIP-57)
// ─────────────────────────────────────────────────────────────────────────────

model ZapReceipt {
  id              String   @id @default(cuid())
  eventId         String   @unique @map("event_id")
  senderPubkey    String   @map("sender_pubkey")
  recipientPubkey String   @map("recipient_pubkey")
  amountMsats     BigInt   @map("amount_msats")
  amountSats      Int      @map("amount_sats")
  comment         String   @default("")
  zappedEventId   String?  @map("zapped_event_id")
  projectId       String?  @map("project_id")
  bolt11          String   @default("")
  createdAt       DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([recipientPubkey])
  @@index([projectId])
  @@index([senderPubkey])
  @@map("zap_receipts")
}

// ─────────────────────────────────────────────────────────────────────────────
// Browser Fingerprints (ban evasion detection)
// ─────────────────────────────────────────────────────────────────────────────

model BrowserFingerprint {
  id              String   @id @default(cuid())
  fingerprintHash String   @map("fingerprint_hash")
  userId          String   @map("user_id")
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fingerprintHash])
  @@index([userId])
  @@map("browser_fingerprints")
}

