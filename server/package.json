{
    "name": "nostrbook-server",
    "version": "0.3.0",
    "private": true,
    "scripts": {
        "dev": "npx tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "start:cluster": "node -e \"require('cluster').fork(); require('cluster').fork(); require('cluster').fork(); require('cluster').fork();\" && node dist/index.js",
        "db:push": "prisma db push",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:seed": "npx tsx prisma/seed.ts",
        "db:studio": "prisma studio",
        "db:reset": "prisma migrate reset --force"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1021.0",
        "@aws-sdk/core": "^3.973.26",
        "@aws-sdk/s3-request-presigner": "^3.1021.0",
        "@prisma/client": "^5.10.0",
        "@smithy/core": "^3.23.13",
        "@smithy/protocol-http": "^5.3.12",
        "@smithy/smithy-client": "^4.12.8",
        "@smithy/types": "^4.13.1",
        "axios": "^1.13.6",
        "bcryptjs": "^2.4.3",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.0",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.0",
        "helmet": "^7.1.0",
        "ioredis": "^5.9.3",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "nostr-tools": "^2.23.0",
        "rss-parser": "^3.13.0",
        "web-push": "^3.6.7",
        "ws": "^8.19.0",
        "zod": "^3.22.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.11.0",
        "@types/web-push": "^3.6.4",
        "@types/ws": "^8.18.1",
        "prisma": "^5.10.0",
        "tsx": "^4.7.0",
        "typescript": "^5.3.0"
    }
}
